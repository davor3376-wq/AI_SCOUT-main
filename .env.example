# ── AI SCOUT — Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default): leave DATABASE_URL empty and set SCOUT_DB_PATH.
# PostgreSQL: set DATABASE_URL to a postgresql:// DSN; SCOUT_DB_PATH is ignored.
DATABASE_URL=
SCOUT_DB_PATH=jobs.db

# ── Data paths ────────────────────────────────────────────────────────────────
SCOUT_RAW_DIR=data/raw
SCOUT_PROCESSED_DIR=data/processed
SCOUT_RESULTS_DIR=results
SCOUT_CACHE_DIR=data/cache
SCOUT_STAC_DIR=data/stac_catalog
SCOUT_STATS_DIR=data/stats

# ── Auth & Security ───────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SCOUT_SECRET_KEY=change-me-in-production

ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7
SCOUT_MIN_PASSWORD_LENGTH=10

# ── Bootstrap admin (used on first startup only) ──────────────────────────────
SCOUT_ADMIN_USERNAME=admin
SCOUT_ADMIN_PASSWORD=ChangeMe123!

# ── Legacy shared API key (backward compat — leave empty to disable) ──────────
SCOUT_API_KEY=

# ── CORS (comma-separated list of allowed origins; empty = allow all) ─────────
SCOUT_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Rate limiting ─────────────────────────────────────────────────────────────
SCOUT_RATE_LIMIT=200/minute

# ── Data retention ────────────────────────────────────────────────────────────
DATA_RETENTION_DAYS=90

# ── Stripe / Billing ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
SCOUT_FRONTEND_URL=http://localhost:3000

# ── Sentinel Hub credentials ──────────────────────────────────────────────────
SH_CLIENT_ID=your-sentinel-hub-client-id
SH_CLIENT_SECRET=your-sentinel-hub-client-secret

# ── Telegram (watchdog alerts) ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Runtime environment ───────────────────────────────────────────────────────
# Values: development | test | production
# In production: SCOUT_SECRET_KEY is mandatory, HSTS headers are enabled,
# dev-open mode is disabled, and HTTP→HTTPS redirect is enforced.
ENVIRONMENT=production
SCOUT_DOMAIN=yoursite.tech

# ── Billing mode ───────────────────────────────────────────────────────────────
# stripe   — full Stripe Checkout (commercial)
# grant    — Stripe checkout disabled; admins assign credits via POST /v1/billing/topup
# disabled — billing router not loaded (fully grant-funded orgs)
BILLING_MODE=grant

# ── PostgreSQL (Docker Compose) ────────────────────────────────────────────────
# Used only when DATABASE_URL is the postgresql:// DSN injected by docker-compose.yml
POSTGRES_PASSWORD=change-me-strong-password

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
